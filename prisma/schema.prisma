generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  name                String?
  avatarUrl           String?             @map("avatar_url")
  authProvider        String              @default("email") @map("auth_provider")
  supabaseId          String              @unique @map("supabase_id")
  homeCity            String?             @map("home_city")
  homeCountry         String?             @map("home_country")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  inventoryCategories InventoryCategory[]
  luggage             Luggage[]
  trips               Trip[]

  @@map("users")
}

model Trip {
  id                   String        @id @default(uuid())
  userId               String?       @map("user_id")
  name                 String?
  destination          String
  startDate            DateTime      @map("start_date")
  endDate              DateTime      @map("end_date")
  tripType             String        @map("trip_type")
  transportMode        String?       @map("transport_mode")
  weather              Json?
  notes                String?
  hotelConfirmationUrl String?       @map("hotel_confirmation_url")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  dayPlans             DayPlan[]
  packingLists         PackingList[]
  tripLuggages         TripLuggage[]
  user                 User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
  @@map("trips")
}

model DayPlan {
  id        String        @id @default(uuid())
  tripId    String        @map("trip_id")
  date      DateTime
  label     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  items     DayPlanItem[]
  trip      Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("day_plans")
}

model DayPlanItem {
  id        String   @id @default(uuid())
  dayPlanId String   @map("day_plan_id")
  name      String
  category  String?
  quantity  Int      @default(1)
  notes     String?
  time      String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  dayPlan   DayPlan  @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)

  @@index([dayPlanId])
  @@map("day_plan_items")
}

model PackingList {
  id         String     @id @default(uuid())
  tripId     String     @map("trip_id")
  name       String     @default("Main Packing List")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  categories Category[]
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("packing_lists")
}

model Category {
  id            String        @id @default(uuid())
  packingListId String        @map("packing_list_id")
  name          String
  order         Int           @default(0)
  packingList   PackingList   @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  items         PackingItem[]

  @@index([packingListId])
  @@map("categories")
}

model PackingItem {
  id            String       @id @default(uuid())
  categoryId    String       @map("category_id")
  name          String
  quantity      Int          @default(1)
  isPacked      Boolean      @default(false) @map("is_packed")
  isCustom      Boolean      @default(false) @map("is_custom")
  order         Int          @default(0)
  tripLuggageId String?      @map("trip_luggage_id")
  packLast      Boolean      @default(false) @map("pack_last")
  category      Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tripLuggage   TripLuggage? @relation(fields: [tripLuggageId], references: [id])

  @@index([categoryId])
  @@index([tripLuggageId])
  @@map("packing_items")
}

model InventoryCategory {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  name      String
  order     Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     InventoryItem[]

  @@index([userId])
  @@map("inventory_categories")
}

model InventoryItem {
  id         String            @id @default(uuid())
  categoryId String            @map("category_id")
  name       String
  quantity   Int               @default(1)
  notes      String?
  isFavorite Boolean           @default(false) @map("is_favorite")
  order      Int               @default(0)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  category   InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("inventory_items")
}

model Luggage {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  name           String
  type           String
  capacity       Int?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  icon           String?
  capacityLiters Float?        @map("capacity_liters")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripLuggages   TripLuggage[]

  @@index([userId])
  @@map("luggage")
}

model TripLuggage {
  id           String        @id @default(uuid())
  tripId       String        @map("trip_id")
  luggageId    String        @map("luggage_id")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  packingItems PackingItem[]
  luggage      Luggage       @relation(fields: [luggageId], references: [id], onDelete: Cascade)
  trip         Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, luggageId])
  @@index([tripId])
  @@index([luggageId])
  @@map("trip_luggage")
}
